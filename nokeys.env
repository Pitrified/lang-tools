# standard env var to check for env vars loading
LANG_TOOLS_SAMPLE_ENV_VAR=sample

## WEBAPP ##

# Google OAuth (required for webapp authentication)
GOOGLE_CLIENT_ID=aaa.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=some-secret-value  # pragma: allowlist secret

# Session security (required in production, auto-generated in dev)
SESSION_SECRET_KEY=some-secret-value  # pragma: allowlist secret

## LLM ##

# OpenAI (used by llm-core chains: translation, conversation, tutor, topics)
OPENAI_API_KEY=sk-some-secret-value  # pragma: allowlist secret

# Optional Azure OpenAI (alternative provider via llm-core)
# AZURE_OPENAI_API_KEY=some-secret-value  # pragma: allowlist secret
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-02-15-preview
